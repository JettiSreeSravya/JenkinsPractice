pipeline {
    // Runs on any available Jenkins agent
    agent any 

    tools {
        // Ensure this matches the Maven name configured in your Jenkins -> Global Tool Configuration
        // If Maven is already in your environment PATH, you can remove this 'tools' block
        maven 'Maven3' 
    }

    stages {
        stage('Checkout') {
            steps {
                // Automatically pulls the latest code from your GitHub repository
                checkout scm
            }
        }
        
        stage('Build & Test') {
            steps {
                // Executes your tests using the surefire plugin config we set up in the pom.xml
                // NOTE: If your Jenkins server runs on Windows, change 'sh' to 'bat'
                sh 'mvn clean test'
            }
        }
    }
    
    post {
        always {
            // This captures the TestNG/Surefire XML reports so you can view the results in the Jenkins UI
            junit 'target/surefire-reports/*.xml'
        }
    }
}
